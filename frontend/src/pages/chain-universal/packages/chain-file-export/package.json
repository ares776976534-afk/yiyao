{
  "name": "@alife/1688-chain-file-export",
  "version": "2.0.1",
  "description": "组件功能描述",
  "files": [
    "esm",
    "es2017",
    "cjs",
    "dist"
  ],
  "main": "esm/index.js",
  "module": "esm/index.js",
  "types": "esm/index.d.ts",
  "exports": {
    ".": {
      "es2017": {
        "types": "./es2017/index.d.ts",
        "default": "./es2017/index.js"
      },
      "default": {
        "types": "./esm/index.d.ts",
        "default": "./esm/index.js"
      }
    },
    "./*": "./*"
  },
  "sideEffects": [
    "dist/*",
    "*.scss",
    "*.less",
    "*.css"
  ],
  "scripts": {
    "start": "ice-pkg start",
    "build": "ice-pkg build",
    "prepublishOnly": "npm run build",
    "eslint": "eslint --cache --ext .js,.jsx,.ts,.tsx ./",
    "eslint:fix": "npm run eslint -- --fix",
    "stylelint": "stylelint \"**/*.{css,scss,less}\"",
    "lint": "npm run eslint && npm run stylelint"
  },
  "keywords": [
    "ice",
    "react",
    "component"
  ],
  "dependencies": {
    "@swc/helpers": "^0.5.1",
    "@ice/jsx-runtime": "^0.2.0",
    "query-string": "^4.2.3",
    "prop-types": "^15.6.0",
    "@alife/1688-chain-file-notification-center": "workspace:*"
  },
  "devDependencies": {
    "@ali/pkg-plugin-dev": "^1.0.0",
    "@ali/pkg-plugin-dev-client": "^1.0.0",
    "@alifd/next": "^1.27.26",
    "@alife/ascp-base": "^7.1.1-beta.5",
    "@alife/theme-103433": "^0.1.0",
    "@applint/spec": "^1.2.3",
    "@ice/pkg": "^1.0.0",
    "@ice/pkg-plugin-docusaurus": "^1.4.18",
    "@ice/remark-react-docgen-docusaurus": "^1.0.1",
    "@ice/runtime": "^1.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "eslint": "^8.0.0",
    "moment": "^2.30.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "stylelint": "^15.0.0"
  },
  "peerDependencies": {
    "react": "^17 || ^18"
  },
  "publishConfig": {
    "registry": "https://registry.anpm.alibaba-inc.com"
  },
